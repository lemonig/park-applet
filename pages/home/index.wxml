<navigation-bar default-data="{{titleProps}}" bind:customBack="parentMethod" ></navigation-bar>

<view class="page-container">
  <view class="header-section {{showHeaderSearch ? 'header-section-show' : ''}}" style="top: {{navBarHeight}}px;">
    <t-search
      placeholder="搜索车位编号，如 A-88"
      shape="round"
      value="{{keyword}}"
      bind:change="onSearchChange"
      bind:submit="onSearch"
      bind:clear="onSearch"
    />
  </view>

  <view class="action-section">
    <view class="action-card action-sale" bind:tap="onActionTap" data-type="1">
      <view class="action-content">
        <view class="action-title">出售</view>
        <view class="action-desc">发布闲置车位</view>
      </view>
      <view class="action-icon">售</view>
    </view>
    <view class="action-card action-rent" bind:tap="onActionTap" data-type="2">
      <view class="action-content">
        <view class="action-title">出租</view>
        <view class="action-desc">快速出租车位</view>
      </view>
      <view class="action-icon">租</view>
    </view>
  </view>

  <view class="list-section">
    <block wx:for="{{pageData}}" wx:key="id">
      <view class="parking-card" bind:tap="onBook" data-id="{{item.id}}">
        <view class="card-left">
          <t-image src="{{item.imageUrl}}" width="200rpx" height="200rpx" shape="round" mode="aspectFill" aria-label="车位图片" />
          <view class="status-badge {{item.available ? 'status-active' : 'status-sold'}}">
            {{item.statusText}}
          </view>
        </view>

        <view class="card-right">
          <view class="card-header">
            <text class="parking-number">{{item.parkingNo}}</text>
            <t-tag variant="light" theme="{{item.type === 1 ? 'warning' : 'primary'}}" size="small">{{item.typeText}}</t-tag>
          </view>

          <view class="card-tags">
            <t-tag wx:if="{{item.positionDesc}}" class="margin-tag" variant="light" theme="primary" size="small">{{item.positionDesc}}</t-tag>
            <t-tag wx:if="{{item.specs}}" class="margin-tag" variant="light" theme="primary" size="small">{{item.specs}}</t-tag>
          </view>

          <view class="card-footer">
            <view class="price-box">
              <text class="currency">¥</text>
              <text class="amount">{{item.price}}</text>
              <text class="unit">{{item.unit}}</text>
            </view>

            <t-button
              theme="{{item.available ? 'primary' : 'default'}}"
              disabled="{{!item.available}}"
              size="small"
              shape="round"
              bind:tap="onBook"
              data-id="{{item.id}}">
              {{item.available ? '查看' : item.statusText}}
            </t-button>
          </view>
        </view>
      </view>
    </block>

    <t-empty wx:if="{{!loading && pageData.length === 0}}" description="暂无车位信息" />

    <view wx:if="{{loading}}" class="list-tip">
      <t-loading theme="circular" size="40rpx" text="加载中..." inherit-color />
    </view>
    <view wx:elif="{{isAllData && pageData.length > 0}}" class="list-tip">没有更多了</view>
  </view>
</view>
