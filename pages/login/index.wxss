.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx 48rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.logo {
  width: 220rpx;
  height: 220rpx;
  border-radius: 48rpx;
  overflow: hidden;
}

.title {
  margin-top: 48rpx;
  font-size: 48rpx;
  font-weight: 600;
  color: #1f2937;
}

.subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.login-panel {
  width: 100%;
  margin-top: 80rpx;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.input {
  font-size: 30rpx;
}

.mode-switch {
  margin-top: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #0252cc;
}

.error-message {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #e34d59;
}
