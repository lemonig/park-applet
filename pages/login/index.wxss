.login-page {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx 64rpx;
  box-sizing: border-box;
  background: #f6f8fb;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background: linear-gradient(160deg, #1e8ae8 0%, #4aa6f0 60%, #f6f8fb 100%);
  border-bottom-left-radius: 64rpx;
  border-bottom-right-radius: 64rpx;
  z-index: 0;
}

.brand {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.18);
}

.title {
  margin-top: 32rpx;
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.login-body {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-top: 64rpx;
}

.login-panel {
  width: 100%;
  padding: 56rpx 40rpx 48rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-sizing: border-box;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.08);
}

.welcome {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
}

.welcome-tip {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

.field {
  margin-top: 32rpx;
  background: #f6f8fb;
  border-radius: 16rpx;
  overflow: hidden;
}

.input {
  font-size: 30rpx;
}

.primary-btn {
  margin-top: 56rpx;
  --td-button-large-height: 96rpx;
  --td-button-border-radius: 48rpx;
  --td-brand-color: #1e8ae8;
}

.wechat-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.ghost-btn {
  margin-top: 36rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1e8ae8;
}

.error-message {
  margin-top: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: #e34d59;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: auto;
  padding-top: 56rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.agreement-text .link {
  color: #1e8ae8;
}
