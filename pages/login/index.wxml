<navigation-bar default-data="{{titleProps}}" back="{{false}}"></navigation-bar>

<view class="login-page" style="min-height: calc(100vh - {{navBarHeight}}px)">
  <t-image class="logo" mode="aspectFill" src="/assets/imgs/bg_welcome.png" aria-label="欢迎" />
  <view class="title">车位</view>
  <view class="subtitle">便捷发布与查看车位信息</view>

  <view wx:if="{{loginMode === 'wechat'}}" class="login-panel">
    <t-button theme="primary" size="large" block loading="{{loading}}" disabled="{{loading}}" bind:tap="handleWechatLogin">微信一键登录</t-button>
    <view class="mode-switch" bind:tap="switchLoginMode">账号密码登录</view>
  </view>

  <view wx:else class="login-panel">
    <t-input value="{{form.account.value}}" placeholder="请输入账号" border="{{false}}" input-class="input" error="{{form.account.validate}}" error-message="{{form.account.errorText}}" bind:change="handleUsernameInput" />
    <t-input value="{{form.password.value}}" placeholder="请输入密码" border="{{false}}" type="password" input-class="input" error="{{form.password.validate}}" error-message="{{form.password.errorText}}" bind:change="handlePasswordInput" />
    <t-button custom-style="margin-top: 50rpx;" theme="primary" loading="{{loading}}" disabled="{{loading}}" block bind:tap="handleLogin">登录</t-button>
    <view class="mode-switch" bind:tap="switchLoginMode">微信一键登录</view>
  </view>

  <view wx:if="{{errMsg}}" class="error-message">{{errMsg}}</view>
</view>

<t-toast id="t-toast" />
